{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "acm_shard.schema.json",
  "type": "object",
  "required": ["schema_version", "cluster_session", "shard_id", "generated_irl", "players"],
  "properties": {
    "schema_version": { "const": 2 },
    "cluster_session": { "type": "string" },
    "shard_id": { "type": "string" },
    "generated_irl": { "type": "number" },
    "catalog_count": { "type": "integer", "minimum": 0 },
    "catalog": {
      "$comment": "object map id -> {title, goal}; the in-game json encoder emits an empty map as []",
      "anyOf": [
        { "type": "object", "additionalProperties": { "$ref": "#/$defs/cat" } },
        { "type": "array", "maxItems": 0 }
      ]
    },
    "players": {
      "$comment": "object map klei_id -> player; the in-game json encoder emits an empty map as []",
      "anyOf": [
        { "type": "object", "additionalProperties": { "$ref": "#/$defs/player" } },
        { "type": "array", "maxItems": 0 }
      ]
    }
  },
  "$defs": {
    "player": {
      "type": "object",
      "required": ["klei_id", "days_survived", "achievements"],
      "properties": {
        "klei_id": { "type": "string" },
        "name": { "type": "string" },
        "prefab": { "type": ["string", "null"] },
        "days_survived": { "type": "number" },
        "last_seen_irl": { "type": "number" },
        "achievements": {
          "$comment": "object map; empty achievements encode as [] from the in-game json encoder",
          "anyOf": [
            { "type": "object", "additionalProperties": { "$ref": "#/$defs/ach" } },
            { "type": "array", "maxItems": 0 }
          ]
        },
        "progress": {
          "$comment": "object map id -> numerator (locked, non-zero); empty encodes as []",
          "anyOf": [
            { "type": "object", "additionalProperties": { "type": "number" } },
            { "type": "array", "maxItems": 0 }
          ]
        }
      }
    },
    "ach": {
      "type": "object",
      "properties": {
        "title": { "type": ["string", "null"] },
        "day": { "type": ["number", "null"] },
        "unlocked_irl": { "type": ["number", "null"] }
      }
    },
    "cat": {
      "type": "object",
      "properties": {
        "title": { "type": ["string", "null"] },
        "goal": { "type": "number" }
      }
    }
  }
}
