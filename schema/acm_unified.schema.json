{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "acm_unified.schema.json",
  "type": "object",
  "required": ["schema_version", "cluster_session", "generated_irl", "player_count", "players"],
  "properties": {
    "schema_version": { "const": 1 },
    "cluster_session": { "type": ["string", "null"] },
    "generated_irl": { "type": "number" },
    "player_count": { "type": "integer", "minimum": 0 },
    "players": { "type": "object", "additionalProperties": { "$ref": "#/$defs/player" } }
  },
  "$defs": {
    "player": {
      "type": "object",
      "required": ["klei_id", "achievements", "achievements_count"],
      "properties": {
        "klei_id": { "type": "string" },
        "name": { "type": ["string", "null"] },
        "prefab": { "type": ["string", "null"] },
        "online": { "type": "boolean" },
        "current_shard": { "type": ["string", "null"] },
        "days_survived": { "type": "number" },
        "last_seen_irl": { "type": "number" },
        "achievements_count": { "type": "integer", "minimum": 0 },
        "achievements": { "type": "object", "additionalProperties": { "$ref": "#/$defs/ach" } }
      }
    },
    "ach": {
      "type": "object",
      "properties": {
        "title": { "type": ["string", "null"] },
        "day": { "type": ["number", "null"] },
        "unlocked_irl": { "type": ["number", "null"] }
      }
    }
  }
}
